classDiagram

    class InputToFormat{
        << Interface >>
        format(sb: StringBuilder, fs: FormattingStrategy)
    }
    
    class AbstractFormatter{
        << Abstract Class >>
        InputToFormat
        AbstractFormatter(InputToFormat)
    }

    class FormattingStrategy{
        << Interface >>
        applyBold(txt: StringBuilder) StringBuilder 
        applyItalic(txt: StringBuilder) StringBuilder 
        applyStrikethrough(txt: StringBuilder) StringBuilder 
        applyInlineCode(txt: StringBuilder) StringBuilder 
        applyLink(txt: StringBuilder, url: StringBuilder) StringBuilder 
    }

    class HtmlStrategy{
        applyH1(txt: StringBuilder) StringBuilder 
        applyParagraph(txt: StringBuilder) StringBuilder 
    }

    class MarkdownStrategy{
        applyHighlight(txt: StringBuilder) StringBuilder
        applyImage(txt: StringBuilder, imgLocation: StringBuilder) StringBuilder
    }

    class Decorator{

    }

    class PlainText{
        PlainText(txt: StringBuilder)
    }

